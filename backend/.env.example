# Backend environment template (copy to backend/.env for local)

# App
PROJECT_NAME=Compulysis OCD Risk Analyzer
API_V1_STR=/api/v1
ENVIRONMENT=production

# Security
SECRET_KEY=change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/compulysis_db

# CORS
# Option A (recommended): comma-separated list
# BACKEND_CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com
# Option B: JSON array
# BACKEND_CORS_ORIGINS=["https://your-frontend-domain.com"]
BACKEND_CORS_ORIGINS=https://your-frontend-domain.com

# In production, disable wildcard local regex by setting this blank
CORS_ALLOW_ORIGIN_REGEX=

# Email (optional)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
